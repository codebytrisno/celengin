{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Celengin",
  "version": "1.0.0",
  "identifier": "com.celengin.app",
  
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devUrl": "http://192.168.1.2:3000",
    "frontendDist": "../public"
  },
  
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Celengin",
        "width": 400,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "url": "http://192.168.1.2:3000"
      }
    ],
    "security": {
      "csp": null
    }
  },
  
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "minSdkVersion": 24
    }
  },
  
  "plugins": {}
}
